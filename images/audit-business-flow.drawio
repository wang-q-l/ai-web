<mxfile><diagram><mxGraphModel>
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- 审计人员泳道 -->
    <mxCell id="10" value="审计人员" style="swimlane;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=14;" vertex="1" parent="1">
      <mxGeometry x="40" y="40" width="900" height="280" as="geometry"/>
    </mxCell>

    <!-- 迎审人员泳道 -->
    <mxCell id="11" value="迎审人员" style="swimlane;startSize=30;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=14;" vertex="1" parent="1">
      <mxGeometry x="40" y="360" width="900" height="280" as="geometry"/>
    </mxCell>

    <!-- 审计人员泳道内的元素 -->
    <!-- 开始 -->
    <mxCell id="20" value="开始" style="ellipse;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=13;" vertex="1" parent="10">
      <mxGeometry x="30" y="80" width="100" height="60" as="geometry"/>
    </mxCell>

    <!-- 创建审计项目 -->
    <mxCell id="21" value="创建审计项目" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="10">
      <mxGeometry x="170" y="80" width="120" height="60" as="geometry"/>
    </mxCell>

    <!-- 执行审计作业 -->
    <mxCell id="22" value="执行审计作业&#10;(准备/实施/报告)" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="10">
      <mxGeometry x="330" y="80" width="140" height="60" as="geometry"/>
    </mxCell>

    <!-- 下发整改问题 -->
    <mxCell id="23" value="下发整改问题" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="10">
      <mxGeometry x="510" y="80" width="120" height="60" as="geometry"/>
    </mxCell>

    <!-- 跟踪整改进展 -->
    <mxCell id="24" value="跟踪整改进展" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="10">
      <mxGeometry x="510" y="180" width="120" height="60" as="geometry"/>
    </mxCell>

    <!-- 验收整改结果 -->
    <mxCell id="25" value="验收整改结果" style="rhombus;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="10">
      <mxGeometry x="670" y="160" width="140" height="100" as="geometry"/>
    </mxCell>

    <!-- 生成整改报告 -->
    <mxCell id="26" value="生成整改报告" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="10">
      <mxGeometry x="680" y="80" width="120" height="60" as="geometry"/>
    </mxCell>

    <!-- 结束 -->
    <mxCell id="27" value="结束" style="ellipse;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=13;" vertex="1" parent="10">
      <mxGeometry x="690" y="10" width="100" height="60" as="geometry"/>
    </mxCell>

    <!-- 迎审人员泳道内的元素 -->
    <!-- 接收整改问题 -->
    <mxCell id="30" value="接收整改问题&#10;(接收人员)" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="11">
      <mxGeometry x="510" y="60" width="120" height="60" as="geometry"/>
    </mxCell>

    <!-- 提交整改方案 -->
    <mxCell id="31" value="提交整改方案" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="11">
      <mxGeometry x="510" y="160" width="120" height="60" as="geometry"/>
    </mxCell>

    <!-- 执行整改 -->
    <mxCell id="32" value="执行整改&#10;(经办人员)" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="11">
      <mxGeometry x="350" y="160" width="120" height="60" as="geometry"/>
    </mxCell>

    <!-- 反馈整改进展 -->
    <mxCell id="33" value="反馈整改进展" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="11">
      <mxGeometry x="350" y="60" width="120" height="60" as="geometry"/>
    </mxCell>

    <!-- 连接线 -->
    <!-- 审计人员流程线 -->
    <mxCell id="40" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;" edge="1" parent="1" source="20" target="21">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="41" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;" edge="1" parent="1" source="21" target="22">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="42" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;" edge="1" parent="1" source="22" target="23">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- 跨泳道：下发整改问题 -> 接收整改问题 -->
    <mxCell id="43" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;dashed=1;" edge="1" parent="1" source="23" target="30">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- 迎审人员流程线 -->
    <mxCell id="44" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;" edge="1" parent="1" source="30" target="31">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="45" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;" edge="1" parent="1" source="31" target="32">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="46" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;" edge="1" parent="1" source="32" target="33">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- 跨泳道：反馈整改进展 -> 跟踪整改进展 -->
    <mxCell id="47" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;dashed=1;" edge="1" parent="1" source="33" target="24">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- 跟踪整改进展 -> 验收整改结果 -->
    <mxCell id="48" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;" edge="1" parent="1" source="24" target="25">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- 验收通过 -> 生成整改报告 -->
    <mxCell id="49" value="通过" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;" edge="1" parent="1" source="25" target="26">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- 验收不通过 -> 执行整改 -->
    <mxCell id="50" value="不通过" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;dashed=1;" edge="1" parent="1" source="25" target="32">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="780" y="560"/>
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- 生成整改报告 -> 结束 -->
    <mxCell id="51" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;" edge="1" parent="1" source="26" target="27">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

  </root>
</mxGraphModel></diagram></mxfile>
