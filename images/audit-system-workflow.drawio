<mxfile><diagram><mxGraphModel>
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- 泳道1：审计人员 -->
    <mxCell id="lane1" value="审计人员" style="swimlane;startSize=40;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=14;horizontal=0;" vertex="1" parent="1">
      <mxGeometry x="40" y="40" width="1400" height="200" as="geometry"/>
    </mxCell>

    <!-- 泳道2：迎审人员（接收人员） -->
    <mxCell id="lane2" value="迎审人员（接收人员）" style="swimlane;startSize=40;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=14;horizontal=0;" vertex="1" parent="1">
      <mxGeometry x="40" y="240" width="1400" height="150" as="geometry"/>
    </mxCell>

    <!-- 泳道3：迎审人员（经办人员） -->
    <mxCell id="lane3" value="迎审人员（经办人员）" style="swimlane;startSize=40;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=14;horizontal=0;" vertex="1" parent="1">
      <mxGeometry x="40" y="390" width="1400" height="200" as="geometry"/>
    </mxCell>

    <!-- 审计人员流程节点 -->
    <mxCell id="node1" value="创建审计项目" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="lane1">
      <mxGeometry x="60" y="70" width="100" height="50" as="geometry"/>
    </mxCell>

    <mxCell id="node2" value="准备阶段" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="lane1">
      <mxGeometry x="200" y="70" width="90" height="50" as="geometry"/>
    </mxCell>

    <mxCell id="node3" value="实施阶段" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="lane1">
      <mxGeometry x="330" y="70" width="90" height="50" as="geometry"/>
    </mxCell>

    <mxCell id="node4" value="报告阶段" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="lane1">
      <mxGeometry x="460" y="70" width="90" height="50" as="geometry"/>
    </mxCell>

    <mxCell id="node5" value="下发整改问题" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="lane1">
      <mxGeometry x="590" y="70" width="100" height="50" as="geometry"/>
    </mxCell>

    <mxCell id="node11" value="审核整改结果" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="lane1">
      <mxGeometry x="1130" y="70" width="100" height="50" as="geometry"/>
    </mxCell>

    <mxCell id="node12" value="后续审计" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="lane1">
      <mxGeometry x="1270" y="70" width="90" height="50" as="geometry"/>
    </mxCell>

    <!-- 接收人员流程节点 -->
    <mxCell id="node6" value="接收整改问题" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="lane2">
      <mxGeometry x="590" y="50" width="100" height="50" as="geometry"/>
    </mxCell>

    <mxCell id="node7" value="分配给经办人员" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="lane2">
      <mxGeometry x="730" y="50" width="110" height="50" as="geometry"/>
    </mxCell>

    <!-- 经办人员流程节点 -->
    <mxCell id="node8" value="提交整改方案" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="lane3">
      <mxGeometry x="870" y="75" width="100" height="50" as="geometry"/>
    </mxCell>

    <mxCell id="node9" value="反馈整改进展" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="lane3">
      <mxGeometry x="1000" y="75" width="100" height="50" as="geometry"/>
    </mxCell>

    <mxCell id="node10" value="提交整改报告" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="lane3">
      <mxGeometry x="1130" y="75" width="100" height="50" as="geometry"/>
    </mxCell>

    <!-- 连接线 -->
    <mxCell id="edge1" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeWidth=2;" edge="1" parent="1" source="node1" target="node2">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="edge2" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeWidth=2;" edge="1" parent="1" source="node2" target="node3">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="edge3" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeWidth=2;" edge="1" parent="1" source="node3" target="node4">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="edge4" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeWidth=2;" edge="1" parent="1" source="node4" target="node5">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="edge5" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#82b366;" edge="1" parent="1" source="node5" target="node6">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="edge6" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeWidth=2;" edge="1" parent="1" source="node6" target="node7">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="edge7" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#d6b656;" edge="1" parent="1" source="node7" target="node8">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="edge8" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeWidth=2;" edge="1" parent="1" source="node8" target="node9">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="edge9" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeWidth=2;" edge="1" parent="1" source="node9" target="node10">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="edge10" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#6c8ebf;" edge="1" parent="1" source="node10" target="node11">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="edge11" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeWidth=2;" edge="1" parent="1" source="node11" target="node12">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

  </root>
</mxGraphModel></diagram></mxfile>
